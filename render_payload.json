{
  "type": "web_service",
  "name": "kadenatrace-api",
  "ownerId": "tea-d5ig36l6ubrc738jn5vg",
  "repo": "https://github.com/sunilblinkoninfra-cyber/KadenaTrace",
  "autoDeploy": "yes",
  "branch": "main",
  "serviceDetails": {
    "env": "node",
    "region": "oregon",
    "plan": "free",
    "envSpecificDetails": {
      "buildCommand": "npm install && npm run build --workspace @kadenatrace/shared && npm run build --workspace @kadenatrace/pact && npm run build --workspace @kadenatrace/api",
      "startCommand": "npm run start:api"
    },
    "envVars": [
      {"key": "CORS_ORIGIN", "value": "https://kadenatrace-web.vercel.app"},
      {"key": "WEB_BASE_URL", "value": "https://kadenatrace-web.vercel.app"},
      {"key": "NODE_ENV", "value": "production"}
    ]
  }
}
