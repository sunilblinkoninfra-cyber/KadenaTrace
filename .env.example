NODE_ENV=development
API_PORT=4000
WEB_PORT=3000

# Frontend → API connection (REQUIRED on Vercel/Render)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_KADENA_NETWORK_ID=testnet04
NEXT_PUBLIC_KADENA_CHAIN_ID=1

# PostgreSQL — if empty, API uses in-memory storage
DATABASE_URL=

# Redis — if empty, traces run inline (synchronous)
REDIS_URL=

# Ethereum public RPC — no API key required
# Cloudflare: https://cloudflare-eth.com
# Ankr:       https://rpc.ankr.com/eth
ETHEREUM_RPC_URL=https://cloudflare-eth.com
BSC_RPC_URL=

# Optional: Covalent GoldRush for richer tx history
COVALENT_API_KEY=

# Bitcoin
BITCOIN_MEMPOOL_URL=https://mempool.space

# Kadena
KADENA_GRAPH_URL=https://graph.kadena.network/graphql
KADENA_CHAIN_ID=1
KADENA_NETWORK_ID=testnet04
KADENA_NODE_URL=https://api.testnet.chainweb.com

# CORS
CORS_ORIGIN=http://localhost:3000

# Dispute flow
DISPUTE_FLOW_ENABLED=true
